{
  "schemaVersion": 1,
  "id": "bpsmod",
  "version": "${version}",
  "name": "BPS Tracker",
  "description": "A lightweight client-side mod to track (broken) blocks per second.",
  "authors": [
    "Harpan"
  ],
  "contact": {
    "sources": "https://github.com/HarpanW/bps-tracker"
  },
  "license": "GPL-3.0-only",
  "icon": "assets/bpsmod/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "me.harpan.bpsmod.client.BpsmodClient"
    ]
  },
  "mixins": [
    {
      "config": "bpsmod.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.5",
    "fabric-api": ">=0.145.1",
    "minecraft": ">=26.1"
  }
}